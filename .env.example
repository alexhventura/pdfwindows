# PDFWINDOWS — Environment Variables
# This app runs 100% in the browser. No API keys are required.

# Optional: canonical site origin for sitemap, robots.txt, canonical, and hreflang.
# Must match the Google Search Console property host exactly (including www).
# On Vercel production, VERCEL_PROJECT_PRODUCTION_URL is used automatically when unset.
# VITE_SITE_ORIGIN=https://www.pdfwindows.com
